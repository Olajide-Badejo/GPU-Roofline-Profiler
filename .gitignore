# Build output
/build/
/report/build/
/report_debug/build/
/report_for_me/build/
*.o
*.obj
*.exe
*.dll
*.lib
*.exp
*.pdb

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Profiler output (large, regenerated)
*.nsys-rep
*.ncu-rep
*.qdrep
*.sqlite

# LaTeX intermediate files
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg

# Raw results are regenerated per run; only results/sample_run is committed.
/results/raw/

# Report PDFs and figures are regenerated from results by one command. The one
# canonical compiled report lives under results/sample_run and is committed
# there, so the repo shows real output without a full rerun.
/report/main.pdf
/report_debug/debug_report.pdf
/report_for_me/report_for_me.pdf
/report/figures/*.pdf
/report/figures/*.png

# Editor / OS
.vscode/
.idea/
*.swp
Thumbs.db
